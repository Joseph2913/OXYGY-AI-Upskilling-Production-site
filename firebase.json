{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/api/health", "function": { "functionId": "health" } },
      { "source": "/api/enhance-prompt", "function": { "functionId": "enhanceprompt" } },
      { "source": "/api/summarize-role", "function": { "functionId": "summarizerole" } },
      { "source": "/api/design-agent", "function": { "functionId": "designagent" } },
      { "source": "/api/agent-setup-guide", "function": { "functionId": "agentsetupguide" } },
      { "source": "/api/design-workflow", "function": { "functionId": "designworkflow" } },
      { "source": "/api/analyze-architecture", "function": { "functionId": "analyzearchitecture" } },
      { "source": "/api/analyze-insight", "function": { "functionId": "analyzeinsight" } },
      { "source": "/api/generate-pathway", "function": { "functionId": "generatepathway" } },
      { "source": "/api/design-dashboard", "function": { "functionId": "designdashboard" } },
      { "source": "/api/generate-prd", "function": { "functionId": "generateprd" } },
      { "source": "/api/app-build-guide", "function": { "functionId": "appbuildguide" } },
      { "source": "/api/evaluate-app", "function": { "functionId": "evaluateapp" } },
      { "source": "/api/evaluate-app-build-plan", "function": { "functionId": "evaluateappbuildplan" } },
      { "source": "/api/generate-n8n-workflow", "function": { "functionId": "generaten8nworkflow" } },
      { "source": "/api/generate-build-guide", "function": { "functionId": "generatebuildguide" } },
      { "source": "/api/resolve-dispute", "function": { "functionId": "resolvedispute" } },
      { "source": "/api/playground", "function": { "functionId": "generateplaygroundprompt" } },
      { "source": "/api/send-invite-email", "function": { "functionId": "sendinviteemail" } },
      { "source": "/api/admin/invite-user", "function": { "functionId": "admininviteuser" } },
      { "source": "/api/admin/scan-domain", "function": { "functionId": "adminscanbydomian" } },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|gif|svg|ico|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
